{
  "name": "@askhub-ai-rag-demo/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "lint": "nx run-many -t lint --parallel",
    "lint:affected": "nx affected -t lint --parallel",
    "lint:fix": "nx run-many -t lint --parallel --fix",
    "typecheck": "nx run-many -t typecheck --parallel",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docker:up": "docker compose --env-file .env -f infrastructure/docker-compose.yml -f infrastructure/docker-compose.dev.yml up -d qdrant ollama ollama-init",
    "docker:up:obs": "docker compose --env-file .env -f infrastructure/docker-compose.yml -f infrastructure/docker-compose.dev.yml up -d langfuse-postgres langfuse",
    "docker:up:all": "docker compose --env-file .env -f infrastructure/docker-compose.yml -f infrastructure/docker-compose.dev.yml up -d",
    "docker:down": "docker compose --env-file .env -f infrastructure/docker-compose.yml down",
    "docker:reset": "docker compose --env-file .env -f infrastructure/docker-compose.yml down -v",
    "docker:logs": "docker compose --env-file .env -f infrastructure/docker-compose.yml logs -f",
    "docker:ps": "docker compose --env-file .env -f infrastructure/docker-compose.yml ps",
    "ollama:pull": "sh tools/scripts/ollama-pull.sh",
    "secrets:gen": "sh tools/scripts/secrets-gen.sh"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,html,css}": [
      "prettier --write"
    ]
  },
  "private": true,
  "devDependencies": {
    "@babel/core": "^7.14.5",
    "@babel/preset-react": "^7.14.5",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@nestjs/schematics": "^10.0.1",
    "@nestjs/testing": "^10.0.2",
    "@next/eslint-plugin-next": "^16.2.9",
    "@nx/devkit": "20.8.4",
    "@nx/eslint": "20",
    "@nx/eslint-plugin": "^20.8.4",
    "@nx/js": "20.8.4",
    "@nx/nest": "20.8.4",
    "@nx/next": "20.8.4",
    "@nx/node": "20.8.4",
    "@nx/playwright": "20.8.4",
    "@nx/react": "20.8.4",
    "@nx/vite": "20",
    "@nx/web": "20.8.4",
    "@nx/webpack": "20.8.4",
    "@nx/workspace": "20",
    "@playwright/test": "^1.60.0",
    "@swc-node/register": "~1.9.1",
    "@swc/cli": "~0.6.0",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jsonc-eslint-parser": "^3.1.0",
    "lint-staged": "^17.0.7",
    "nx": "20.8.4",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "tslib": "^2.3.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.2",
    "@nestjs/core": "^10.0.2",
    "@nestjs/platform-express": "^10.0.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "axios": "^1.6.0",
    "langfuse": "^3.38.20",
    "next": "~15.2.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "zod": "^4.4.3"
  }
}
