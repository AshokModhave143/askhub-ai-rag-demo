{
  "name": "@askhub-ai-rag-demo/api",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "webpack-cli build",
          "cwd": "{projectRoot}",
          "args": [
            "--node-env=production"
          ]
        },
        "configurations": {
          "development": {
            "args": [
              "--node-env=development"
            ]
          }
        }
      },
      "serve": {
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "@askhub-ai-rag-demo/api:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "@askhub-ai-rag-demo/api:build:development"
          },
          "production": {
            "buildTarget": "@askhub-ai-rag-demo/api:build:production"
          }
        }
      }
    },
    "tags": [
      "scope:api",
      "type:app"
    ]
  },
  "dependencies": {
    "@askhub-ai-rag-demo/adapter-llm-ollama": "workspace:^",
    "@askhub-ai-rag-demo/adapter-vector-qdrant": "workspace:^",
    "@askhub-ai-rag-demo/core-domain": "workspace:^",
    "@askhub-ai-rag-demo/core-ports": "workspace:^",
    "@askhub-ai-rag-demo/rag-pipeline": "workspace:^",
    "@askhub-ai-rag-demo/shared-config": "workspace:^",
    "reflect-metadata": "^0.2.2",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.11",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.11",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.11",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/testing": "^11.0.11",
    "@qdrant/js-client-rest": "^1.18.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "joi": "^18.2.1",
    "mammoth": "^1.12.0",
    "mime-types": "^3.0.2",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^2.4.5",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^2.1.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/uuid": "^11.0.0",
    "null-loader": "^4.0.1"
  }
}
