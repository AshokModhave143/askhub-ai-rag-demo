# ─── Ports ─────────────────────────────────────────────
WEB_PORT=3000
API_PORT=3001
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
OLLAMA_PORT=11434
LANGFUSE_PORT=3100
LANGFUSE_PG_PORT=5432

# ─── Ollama ────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODELS=qwen3:4b,qwen3:8b,nomic-embed-text
OLLAMA_KEEP_ALIVE=30m

# ─── Qdrant ────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=askhub_docs

# ─── Langfuse ──────────────────────────────────────────
LANGFUSE_PG_USER=langfuse
LANGFUSE_PG_PASSWORD=langfuse
LANGFUSE_PG_DB=langfuse
LANGFUSE_SECRET=replace-with-openssl-rand-base64-32
LANGFUSE_SALT=replace-with-openssl-rand-base64-32
LANGFUSE_ENCRYPTION_KEY=replace-with-openssl-rand-hex-32
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3100

# ─── API ───────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
JWT_SECRET=replace-with-openssl-rand-base64-64
JWT_EXPIRES_IN=12h
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50

# ─── OTEL ──────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=askhub-api
